{
  "name": "@repo/prisma-db",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./lib/prisma.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
