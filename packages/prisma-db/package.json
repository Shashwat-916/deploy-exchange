    "build": "bun ./lib/prisma.ts ",
    "test": "bun test"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "prisma": "^7.9.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@prisma/client-runtime-utils": "^7.9.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  }
